{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash .claude/hooks/session-start.sh 2>/dev/null || true",
        "description": "Load persisted session context on startup"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash .claude/hooks/session-end.sh 2>/dev/null || true",
        "description": "Save session metadata on exit"
      }
    ],
    "PreToolUse": [],
    "PostToolUse": []
  }
}
